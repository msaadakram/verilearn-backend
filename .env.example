NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=verilearn
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
MAILERSEND_API_KEY=mlsn.your_mailersend_api_key_here
MAILERSEND_FROM_EMAIL=noreply@your-verified-domain.com
MAILERSEND_FROM_NAME=Verilearn
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
PASSWORD_RESET_CODE_TTL_MINUTES=10
CNIC_OCR_SERVICE_URL=http://127.0.0.1:8001/ocr
CNIC_OCR_TIMEOUT_MS=90000
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
CNIC_FALLBACK_TO_OCR=true
CNIC_STOP_OCR_MODEL_ON_GEMINI_SUCCESS=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-jwt-or-leave-empty
SUPABASE_SECRET_KEY=your-supabase-secret-key-or-leave-empty
SUPABASE_STORAGE_BUCKET=profile-images
SUPABASE_STORAGE_FOLDER=avatars
